{
  "version": 2,
  "buildCommand": false,
  "installCommand": false,
  "framework": null,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "github": {
    "silent": true,
    "autoAlias": true
  }
}
