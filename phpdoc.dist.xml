<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
        configVersion="3"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="https://www.phpdoc.org"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/phpDocumentor/phpDocumentor/master/data/xsd/phpdoc.xsd"
>
    <title>Kaizen Documentation</title>
    <paths>
        <output>docs</output>
        <cache>build/cache</cache>
    </paths>
    <version number="3.0.0">
        <api>
            <source dsn=".">
                <path>app</path>
                <path>config</path>
                <path>routes</path>
                <path>resources/views</path>
            </source>
            <ignore hidden="true" symlinks="true">
                <path>vendor/**/*</path>
                <path>tests/**/*</path>
                <path>storage/**/*</path>
                <path>public/**/*</path>
                <path>node_modules/**/*</path>
            </ignore>
            <extensions>
                <extension>php</extension>
                <extension>blade.php</extension>
            </extensions>
            <default-package-name>Kaizen</default-package-name>
        </api>
        <guide>
            <source dsn=".">
                <path>docs</path>
            </source>
            <output>guides</output>
        </guide>
    </version>
</phpdocumentor> 