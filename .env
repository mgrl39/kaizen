# Desactiva el almacenamiento en caché para desarrollo
VIEW_CACHE=false
CONFIG_CACHE=false
ROUTE_CACHE=false

# Aseguramos que tenemos el CORS para las APIs
SANCTUM_STATEFUL_DOMAINS=${APP_ADDRESS}:${APP_PORT}
SESSION_DOMAIN=${APP_ADDRESS}
