APP_NAME="Sistema de Cines"
APP_ENV=local
APP_KEY=base64:wviAjvdN2ApurbEeBHliJbsDRmT/WK5wnkY2w5wCaV4=
APP_DEBUG=true

APP_ADDRESS=localhost
APP_PROTOCOL=http
APP_PORT=8000
APP_URL=${APP_PROTOCOL}://${APP_ADDRESS}:${APP_PORT}
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
